<?php

/**
 * @file
 * FitLife reservatie module.
 */

/**
 * Implements hook_page_attachments().
 */
function fitlife_reservatie_page_attachments(array &$attachments) {
  $attachments['#attached']['library'][] = 'fitlife_reservatie/producten';
}

/**
 * Implements hook_form_alter().
 */
function fitlife_reservatie_form_alter(&$form, $form_state, $form_id) {
  if (strpos($form_id, 'contact_message_') === 0) {
    $form['contact_hero'] = [
      '#markup' => '<div class="contact-hero"><h1>📩 Contacteer ons</h1><p>Heb je een vraag? Wij helpen je graag verder!</p></div>',
      '#weight' => -100,
    ];
  }
}
